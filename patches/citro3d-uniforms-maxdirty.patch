diff --git a/include/c3d/uniforms.h b/include/c3d/uniforms.h
index 9e50153..2036e52 100644
--- a/include/c3d/uniforms.h
+++ b/include/c3d/uniforms.h
@@ -11,10 +11,14 @@ extern u16      C3D_BoolUnifs[2];
 extern bool C3D_FVUnifDirty[2][C3D_FVUNIF_COUNT];
 extern bool C3D_IVUnifDirty[2][C3D_IVUNIF_COUNT];
 extern bool C3D_BoolUnifsDirty[2];
+extern int  C3D_FVUnifMaxDirty[2];
 
 static inline C3D_FVec* C3D_FVUnifWritePtr(GPU_SHADER_TYPE type, int id, int size)
 {
 	int i;
+	int end = id + size;
+	if (end > C3D_FVUnifMaxDirty[type])
+		C3D_FVUnifMaxDirty[type] = end;
 	for (i = 0; i < size; i ++)
 		C3D_FVUnifDirty[type][id+i] = true;
 	return &C3D_FVUnif[type][id];
diff --git a/source/uniforms.c b/source/uniforms.c
index ac4b36e..b59f31a 100644
--- a/source/uniforms.c
+++ b/source/uniforms.c
@@ -8,6 +8,7 @@ u16      C3D_BoolUnifs[2];
 bool C3D_FVUnifDirty[2][C3D_FVUNIF_COUNT];
 bool C3D_IVUnifDirty[2][C3D_IVUNIF_COUNT];
 bool C3D_BoolUnifsDirty[2];
+int  C3D_FVUnifMaxDirty[2];
 
 static struct
 {
@@ -37,8 +38,9 @@ void C3D_UpdateUniforms(GPU_SHADER_TYPE type)
 		i = 0;
 	}
 
-	// Update FVec uniforms
-	while (i < C3D_FVUNIF_COUNT)
+	// Update FVec uniforms (scan only up to maxDirty bound)
+	int maxDirty = C3D_FVUnifMaxDirty[type];
+	while (i < maxDirty)
 	{
 		if (!C3D_FVUnifDirty[type][i])
 		{
@@ -48,7 +50,7 @@ void C3D_UpdateUniforms(GPU_SHADER_TYPE type)
 
 		// Find the number of consecutive dirty uniforms
 		int j;
-		for (j = i; j < C3D_FVUNIF_COUNT && C3D_FVUnifDirty[type][j]; j ++);
+		for (j = i; j < maxDirty && C3D_FVUnifDirty[type][j]; j ++);
 
 		// Upload the uniforms
 		GPUCMD_AddWrite(GPUREG_VSH_FLOATUNIFORM_CONFIG+offset, 0x80000000|i);
@@ -65,6 +67,7 @@ void C3D_UpdateUniforms(GPU_SHADER_TYPE type)
 		// Advance
 		i = j;
 	}
+	C3D_FVUnifMaxDirty[type] = 0;
 
 	// Update IVec uniforms
 	for (i = 0; i < C3D_IVUNIF_COUNT; i ++)
@@ -90,8 +93,13 @@ void C3Di_DirtyUniforms(GPU_SHADER_TYPE type)
 	C3D_BoolUnifsDirty[type] = true;
 	if (C3Di_ShaderFVecData[type].count)
 		C3Di_ShaderFVecData[type].dirty = true;
+	C3D_FVUnifMaxDirty[type] = 0;
 	for (i = 0; i < C3D_FVUNIF_COUNT; i ++)
+	{
 		C3D_FVUnifDirty[type][i] = C3D_FVUnifDirty[type][i] || C3Di_FVUnifEverDirty[type][i];
+		if (C3D_FVUnifDirty[type][i])
+			C3D_FVUnifMaxDirty[type] = i + 1;
+	}
 	for (i = 0; i < C3D_IVUNIF_COUNT; i ++)
 		C3D_IVUnifDirty[type][i] = C3D_IVUnifDirty[type][i] || C3Di_IVUnifEverDirty[type][i];
 }
