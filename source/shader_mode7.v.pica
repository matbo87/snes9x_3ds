; Uniforms
.fvec       projection[4]       ; #0 - 3
.fvec       textureScale        ; #4
.fvec       textureOffset       ; #5 (not used here, but for convenience)
.fvec     	updateFrame         ; #6

; Constants
.constf c_base          (0, 1, 2, 8)    ; (x, y, z, w)
.constf c_tex           (16384, 0.0625, -16, 0.004032258064516)

; Outputs
.out        outpos      position
.out        outtex      texcoord0
.out        outcol      color

; Inputs
.alias      inpos       v0      ; (x, y+depth [0x4000], flip+texbase, updateFrame)

.entry vmain
.proc vmain
    mov     r0, inpos
    mov     r10, c_base.xxxy

    mov     r1, updateFrame             ; r2 = updateFrame 
    cmp     r0.w, lt, lt, r1.w          ; if r0.w < updateFrame
    jmpc    cmp.x, do_not_draw          ; then, skip computations

    ; computing texturePos
    ;
    mov     r1, c_base
    mov     r2, c_tex

    mul     r9.y, r0.z, r2.y            ; r9.y = r0.z / 16
    flr     r9.y, r9.y                  ; r9.y = floor (r9), r9.y is the base texture y coordinate
    mad     r9.x, r9.y, r2.z, r0.z      ; r9.x = r0.z + r9.y * (-16), r9.x is the base texture x coordinate

    mad     r10.xy, r9.xy, r1.w, r10.xy ; r10.xy = r10.xy + r9.xy * 8

    ; depth computation
    ;
    mov     r0.z, r1.x                  ; r0.z = 0
    cmp     r0.y, lt, lt, r2.x          ; is r0.y < 16384?
    jmpc    cmp.x, depth_lt_16384       ; if yes then do nothing, else:
    add     r0.y, r0.y, -r2.x           ; r0.y = r0.y - 16384
    mov     r0.z, r1.y                  ; r0.z = 1

depth_lt_16384:
    mov     outpos, r0
    mov     outtex, r10
    mov     outcol, c_base.xxxx         ; always (0,0,0,0)

    end

do_not_draw:
    mov     outpos, c_base.xxxx
    mov     outtex, c_base.xxxx
    mov     outcol, c_base.xxxx

    end

.end