; Uniforms
.fvec       projection[4]       ; #0 - 3
.fvec       textureScale        ; #4
.fvec       textureOffset       ; #5 
                                ; x = texture offset (0.0 or 1.0 for mode5/6 hi-res flipping)

; Constants
.constf c_base          (0, 1, 2, 8)    ; (x, y, z, w)
.constf c_tex           (32768, 16384, 0.0078125, 128)
.constf c_alpha         (24576, 8192, 255, 0)
.constf c_depth         (0.0625, -256, 0.00390625, 0)

; Outputs
.out        outpos      position
.out        outtex      texcoord0
.out        outcol      color

; Inputs (defined as aliases for convenience)
.alias      inpos       v0      ; x = x (xxxxxxxx xxxxxxxx) 
                                ; x: x (-256 to 511)

                                ; y = y (0aa0dddd yyyyyyyy)
                                ; a: alpha (0 = 0.0, 1 = 0.5, 2 = 1.0, 3 = undefined)
                                ; d: depth (0 - 16)
                                ; y: y (0 - 255)
                                 
                                ; z = (vhtttttt tttttttt) or 0
                                ; v: Flip vertical
                                ; h: Flip horizontal
                                ; t: tex base
                                ; w = 1
.alias      intex       v1      ; (u, v) or (r, g, b, a)

.entry vmain
.proc vmain
    mov     r0, inpos
    mov     r10, intex

    mov     r1, c_base
    mov     r2, c_tex
    
    add     r10.x, textureOffset.x, r10.x

    cmp     r0.z, eq, eq, r1.x
    jmpc    cmp.x, alpha_computation

computing_vflip:
    cmp     r0.z, ge, ge, r1.x          ; is r0.z > 0? (or 0x8000 is not set)
    jmpc    cmp.x, computing_hflip      ; if no vflip go to computing_hflip, else:
    mad     r10.y, r10.y, -r1.y, r1.w   ; r10.y = (r10.y * -1) + 8
    add     r0.z, r0.z, r2.x            ; r0.z = r0.z + 32768 (removes the 0x8000 bit)

computing_hflip:
    cmp     r0.z, lt, lt, r2.y          ; is r0.z < 16384? (or 0x4000 is not set)
    jmpc    cmp.x, computing_tex_pos    ; if no hflip go to no_hflip, else:
    mad     r10.x, r10.x, -r1.y, r1.w   ; r10.x = (r10.x * -1) + 8
    add     r0.z, r0.z, -r2.y           ; r0.z = r0.z - 16384 (removes the 0x4000 bit)

computing_tex_pos:
    mul     r9.y, r0.z, r2.z            ; r9.y = r0.z * (1/128)
    flr     r9.y, r9.y                  ; r9.y = floor(r9.y)
    mad     r9.x, r9.y, -r2.w, r0.z     ; r9.x = r0.z - r9.y * 128
    mad     r10.xy, r9.xy, r1.w, r10.xy ; r10.xy = r10.xy + r9.xy * 8
    
alpha_computation:
    mov     r11, intex
    mov     r1, c_alpha

    cmp     r0.y, lt, lt, r1.x          ; is r0.y < 24576?
    jmpc    cmp.x, alpha_lt_0_0         ; if yes then do nothing, else:
    add     r0.y, r0.y, -r1.x           ; r0.y = r0.y - 24576
    mov     r11.w, c_base.y             ; alpha = 1 (slightly more alpha leak, but not visible...)
alpha_lt_0_0:
    cmp     r0.y, lt, lt, r2.y          ; is r0.y < 16384?
    jmpc    cmp.x, alpha_lt_1_0         ; if yes then do nothing, else:
    add     r0.y, r0.y, -r2.y           ; r0.y = r0.y - 16384
    mov     r11.w, r1.z                 ; alpha = 255
alpha_lt_1_0:
    cmp     r0.y, lt, lt, r1.y          ; is r0.y < 8192?
    jmpc    cmp.x, depth_computation    ; if yes then do nothing, else:
    add     r0.y, r0.y, -r1.y           ; r0.y = r0.y - 8192
    mov     r11.w, r2.w                 ; alpha = 128

depth_computation:
    cmp     r0.y, lt, lt, r1.w          ; if r0.y < 0, 
    jmpc    cmp.x, draw                 ; then do nothing, else:

    mov     r1, c_depth
    mul     r0.z, r0.y, r1.z            ; r0.z = r0.y / 256
    flr     r0.z, r0.z                  ; r0.z = floor(r0.y / 256)
    mad     r0.y, r0.z, r1.y, r0.y      ; r0.y = r0.y + r0.z * (-256) = r0.y - floor(r0.y / 256) * 256
    mul     r0.z, r0.z, r1.x            ; r0.z = r0.z / 16

draw:
    ; pass through, set final values for projection, textureScale and color in geo shader
    mov     outpos, r0
    mov     outtex, r10
    mov     outcol, r11

    end
.end